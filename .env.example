# Endpoint that receives newsletter subscriptions (POST JSON: { email })
VITE_NEWSLETTER_ENDPOINT=/api/newsletter

# Endpoint that receives contact requests (POST JSON)
VITE_CONTACT_ENDPOINT=/api/contact

# Public URL for the Hello Kids website
VITE_HELLO_KIDS_URL=https://kids.paroteen.com

# Server-side email configuration for API routes
RESEND_API_KEY=
CONTACT_RECEIVER_EMAIL=
RESEND_FROM_EMAIL=

# Optional comma-separated CORS allow-list for API routes
ALLOWED_ORIGINS=
